# copy to .env and tweak. everything's prefixed GATEWAY_

# jwt auth (stage 2)
GATEWAY_JWT_SECRET=dev-insecure-secret-change-me
GATEWAY_JWT_ALGORITHM=HS256
# GATEWAY_JWT_AUDIENCE=my-api
# GATEWAY_JWT_ISSUER=my-issuer

# rate limit / token bucket (stage 3)
GATEWAY_REDIS_URL=redis://localhost:6379/0
GATEWAY_RATE_CAPACITY=20
GATEWAY_RATE_REFILL_PER_SEC=5

# sig files (stages 4 + 8) - defaults are fine, only set to override
# GATEWAY_INJECTION_SIGNATURES_PATH=signatures/injection_signatures.json
# GATEWAY_INTERNAL_SIGNATURES_PATH=signatures/internal_signatures.json

# ner model (stage 6). md catches more than sm but is bigger
GATEWAY_SPACY_MODEL=en_core_web_md

# provider / egress (stage 7). mock = echo, no key needed
GATEWAY_PROVIDER=mock
GATEWAY_PROVIDER_API_KEY=
GATEWAY_PROVIDER_MODEL=claude-3-5-sonnet-20241022
# GATEWAY_PROVIDER_BASE_URL=
GATEWAY_PROVIDER_TIMEOUT_S=60

# audit log (stage 9)
GATEWAY_AUDIT_DB_PATH=audit.db
GATEWAY_STORE_REDACTED_PROMPT=false
